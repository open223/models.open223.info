sition":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"VVNZ1eLEQm"},{"type":"inlineCode","value":"shacl_engine='topquadrant'","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"QCZ8yW3QRn"},{"type":"text","value":" parameter from the ","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"fzcVsC1oDH"},{"type":"inlineCode","value":"BuildingMOTIF","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"BM3la4DPIJ"},{"type":"text","value":" constructor.\nBe warned that without the ","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"QTX9vkguAy"},{"type":"inlineCode","value":"shacl_engine='topquadrant'","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"vmpjyzOuLb"},{"type":"text","value":" parameter, the validation process will be slower.","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"IQni6GnjXc"}],"key":"ACS6OWp1bn"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"BuildingMOTIF installation","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"key":"yhgwYVxXUV"}],"key":"P5KlCKHclO"},{"type":"paragraph","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"children":[{"type":"text","value":"To install the ","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"JETJTzvhbV"},{"type":"inlineCode","value":"buildingmotif","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"gkHpB4lSAL"},{"type":"text","value":" library, you can use the following command:","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"GWlnSK1tTw"}],"key":"ip4CD0Eqnw"},{"type":"code","lang":"shell","value":"pip install 'buildingmotif[topquadrant] @ git+https://github.com/NREL/buildingmotif.git@develop'","position":{"start":{"line":72,"column":1},"end":{"line":74,"column":1}},"key":"aLAQfM3qZO"},{"type":"paragraph","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"If you do not have Java installed, you can use the following command to install the library:","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"Fpum4Zu8e1"}],"key":"FayrXfIjkn"},{"type":"code","lang":"shell","value":"pip install 'buildingmotif @ git+https://github.com/NREL/buildingmotif.git@develop'","position":{"start":{"line":78,"column":1},"end":{"line":80,"column":1}},"key":"BSz14XD06K"}],"class":"dropdown","key":"zuHFlRDXJX"}],"key":"eMioBRjw8Z"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from buildingmotif import BuildingMOTIF\nfrom buildingmotif.dataclasses import Library, Model\nimport ontoenv\nimport logging\n\n# Create a BuildingMOTIF object. If you do not have Java installed, remove the \"shacl_engine\" parameter\nbm = BuildingMOTIF('sqlite://', shacl_engine='topquadrant', log_level=logging.ERROR)\n\n# load 223P library. We will load a recent copy from the models.open223.info\n# git repository; later, we will load this from the location of the actual standard\ns223 = Library.load(ontology_graph=\"https://open223.info/223p.ttl\", infer_templates=False, run_shacl_inference=False)\nunit = Library.load(ontology_graph=\"http://qudt.org/3.1.1/vocab/unit\", infer_templates=False, run_shacl_inference=False)\nquantitykind = Library.load(ontology_graph=\"http://qudt.org/3.1.1/vocab/quantitykind\", infer_templates=False, run_shacl_inference=False)\n\n# load the model into the BuildingMOTIF instance\nmodel = Model.create(\"urn:guideline36-2021-A-7\")\nmodel.graph.parse(\"https://models.open223.info/guideline36-2021-A-7.ttl\")\n\n# validate the model against 223P ontology\nctx = model.validate([s223.get_shape_collection(),\n                      unit.get_shape_collection(),\n                      quantitykind.get_shape_collection()],\n                     error_on_missing_imports=False)\n\n# print the validation result\nprint(f\"Model is valid: {ctx.valid}\")\n\n# if the model is invalid, print the validation report\nif not ctx.valid:\n    print(ctx.report_string[:1000]) # first 1000 characters of the report\n\n# BuildingMOTIF can also interpret the report to provide recommendations on fixes\nfor focus_node, diffs in ctx.get_reasons_with_severity(\"Violation\").items():\n    if len(diffs) == 0:\n        continue\n    print(focus_node)\n    for diff in diffs:\n        print(\"  - \" + diff.reason())","key":"iOGPxDUPm4"},{"type":"outputs","id":"yPGQEzLTt1wo97Hg0jwi5","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Model is valid: 0\nValidation Report\nConforms: False\n\nValidation Results (14):\n\n--- Result 1 ---\nSeverity: sh:Warning\nFocus Node: <http://data.ashrae.org/standard223/1.0/data/guideline36-2021-A-7#zone-temp>\nMessage: s223: An `ObservableProperty` is usually referred to by a `Sensor` using the relation `observes`.\nPath: _:nba68a4aeacd04b66a166d602640f7416b3\nSource Constraint: sh:MinCountConstraintComponent\nSource Shape: <urn:well-known/9110befc>\n\n--- Result 2 ---\nSeverity: sh:Warning\nFocus Node: <http://data.ashrae.org/standard223/1.0/data/guideline36-2021-A-7#zone-co2-concentration>\nMessage: s223: An `ObservableProperty` is usually referred to by a `Sensor` using the relation `observes`.\nPath: _:nba68a4aeacd04b66a166d602640f7416b5\nSource Constraint: sh:MinCountConstraintComponent\nSource Shape: <urn:well-known/9110befc>\n\n--- Result 3 ---\nSeverity: sh:Warning\nFocus Node: <http://data.ashrae.org/standard223/1.0/data/guideline36-2021-A-7#DualDuctInletSensors-cold-deck-damper-position>\nMessage: s223: An `Obser\n"},"key":"duo0dGZRVl"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"http://data.ashrae.org/standard223#Numerical-NumberOfElectricalPhases\n  - http://qudt.org/vocab/quantitykind/NumberOfElectricalPhases on http://data.ashrae.org/standard223#Numerical-NumberOfElectricalPhases needs to be a http://qudt.org/schema/qudt/QuantityKind\nhttp://data.ashrae.org/standard223#NumberOfElectricalPhases-SinglePhase\n  - http://qudt.org/vocab/quantitykind/NumberOfElectricalPhases on http://data.ashrae.org/standard223#NumberOfElectricalPhases-SinglePhase needs to be a http://qudt.org/schema/qudt/QuantityKind\nhttp://data.ashrae.org/standard223#NumberOfElectricalPhases-ThreePhase\n  - http://qudt.org/vocab/quantitykind/NumberOfElectricalPhases on http://data.ashrae.org/standard223#NumberOfElectricalPhases-ThreePhase needs to be a http://qudt.org/schema/qudt/QuantityKind\n"},"key":"GyFBOztCBX"}],"key":"WjO8InFOQP"}],"key":"RRp1rMIvaD"}],"key":"zh8QzV8C7o"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"ASHRAE Guideline 36-2021 A-4 Parallel Fan-Powered Terminal Unit, Variable Volume Fan","url":"/guideline36-2021-a-4","group":"Example Systems"},"next":{"title":"ASHRAE Guideline 36-2021 A-8 Dual Duct Terminal Unit with Discharge Sensor","url":"/guideline36-2021-a-8","group":"Example Systems"}}},"domain":"http://localhost:3000"}