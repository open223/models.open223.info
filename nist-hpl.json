t the validation report.","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"ZmK08XUK7Q"}],"key":"lETaj2RV2s"},{"type":"paragraph","position":{"start":{"line":81,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"text","value":"To run this code, you need to have Java installed on your system. If you do not have Java installed, you can remove the ","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"xNtRpA7Dgo"},{"type":"inlineCode","value":"shacl_engine='topquadrant'","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"sdOikchmhF"},{"type":"text","value":" parameter from the ","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"GVgAQE6Bkq"},{"type":"inlineCode","value":"BuildingMOTIF","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"tBChGYb2ym"},{"type":"text","value":" constructor.\nBe warned that without the ","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"Q4xWT5Ipvi"},{"type":"inlineCode","value":"shacl_engine='topquadrant'","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"SxdzjPonJZ"},{"type":"text","value":" parameter, the validation process will be slower.","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"ESyaR9XANj"}],"key":"koUZ4IKiqF"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"BuildingMOTIF installation","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"key":"MVJeL9uadS"}],"key":"X8PQUscqk7"},{"type":"paragraph","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"children":[{"type":"text","value":"To install the ","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"key":"wGILBqzyvg"},{"type":"inlineCode","value":"buildingmotif","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"key":"iQ0g3KPTRd"},{"type":"text","value":" library, you can use the following command:","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"key":"KaLNgYc3SC"}],"key":"mG04uRw26K"},{"type":"code","lang":"shell","value":"pip install 'buildingmotif[topquadrant] @ git+https://github.com/NREL/buildingmotif.git@develop'","position":{"start":{"line":88,"column":1},"end":{"line":90,"column":1}},"key":"xQZsb8D0uo"},{"type":"paragraph","position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"children":[{"type":"text","value":"If you do not have Java installed, you can use the following command to install the library:","position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"key":"IJ2c8tYG4g"}],"key":"kBuHMwLdl1"},{"type":"code","lang":"shell","value":"pip install 'buildingmotif @ git+https://github.com/NREL/buildingmotif.git@develop'","position":{"start":{"line":94,"column":1},"end":{"line":96,"column":1}},"key":"qbaJi3G3ND"}],"class":"dropdown","key":"zga8gWsHVt"}],"key":"KtRFv8zOJ6"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from buildingmotif import BuildingMOTIF\nfrom buildingmotif.dataclasses import Library, Model\nimport ontoenv\nimport logging\n\n# Create a BuildingMOTIF object. If you do not have Java installed, remove the \"shacl_engine\" parameter\nbm = BuildingMOTIF('sqlite://', shacl_engine='topquadrant', log_level=logging.ERROR)\n\n# load 223P library. We will load a recent copy from the models.open223.info\n# git repository; later, we will load this from the location of the actual standard\ns223 = Library.load(ontology_graph=\"https://open223.info/223p.ttl\", infer_templates=False, run_shacl_inference=False)\nunit = Library.load(ontology_graph=\"http://qudt.org/3.1.1/vocab/unit\", infer_templates=False, run_shacl_inference=False)\nquantitykind = Library.load(ontology_graph=\"http://qudt.org/3.1.1/vocab/quantitykind\", infer_templates=False, run_shacl_inference=False)\n\n# load the model into the BuildingMOTIF instance\nmodel = Model.create(\"urn:NIST-HPL\")\nmodel.graph.parse(\"https://models.open223.info/NIST-HPL.ttl\")\n\n# validate the model against 223P ontology\nctx = model.validate([s223.get_shape_collection(),\n                      unit.get_shape_collection(),\n                      quantitykind.get_shape_collection()],\n                     error_on_missing_imports=False)\n\n# print the validation result\nprint(f\"Model is valid: {ctx.valid}\")\n\n# if the model is invalid, print the validation report\nif not ctx.valid:\n    print(ctx.report_string[:1000]) # first 1000 characters of the report\n\n# BuildingMOTIF can also interpret the report to provide recommendations on fixes\nfor focus_node, diffs in ctx.get_reasons_with_severity(\"Violation\").items():\n    if len(diffs) == 0:\n        continue\n    print(focus_node)\n    for diff in diffs:\n        print(\"  - \" + diff.reason())","key":"IQFvB94HW6"},{"type":"outputs","id":"inDBPBwZmFeHD4m167Vwb","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Model is valid: 0\nValidation Report\nConforms: False\n\nValidation Results (14):\n\n--- Result 1 ---\nSeverity: sh:Warning\nFocus Node: <http://example.org/HPL#OA_Connection_1_Temp_6>\nMessage: s223: An `ObservableProperty` is usually referred to by a `Sensor` using the relation `observes`.\nPath: _:nec26a2ee5ba84496a5a84de36c60e49db3\nSource Constraint: sh:MinCountConstraintComponent\nSource Shape: <urn:well-known/4f20f9ed>\n\n--- Result 2 ---\nSeverity: sh:Warning\nFocus Node: <http://example.org/HPL#OA_Connection_1_Temp_5>\nMessage: s223: An `ObservableProperty` is usually referred to by a `Sensor` using the relation `observes`.\nPath: _:nec26a2ee5ba84496a5a84de36c60e49db5\nSource Constraint: sh:MinCountConstraintComponent\nSource Shape: <urn:well-known/4f20f9ed>\n\n--- Result 3 ---\nSeverity: sh:Violation\nFocus Node: ns2:NumberOfElectricalPhases-SinglePhase\nMessage: s223: An `EnumerationKind-Numerical` shall be associated with exactly one `QuantityKind` using the relation `qudt:hasQuantityKind`.\nPath: ns1:hasQuantityKind\n"},"key":"JkCqCjplJo"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"http://example.org/HPL#TemperatureSensor_30\n  - http://example.org/HPL#TemperatureSensor_30 expected 1 uses of path ns2:hasObservationLocation\nhttp://data.ashrae.org/standard223#Numerical-NumberOfElectricalPhases\n  - http://qudt.org/vocab/quantitykind/NumberOfElectricalPhases on http://data.ashrae.org/standard223#Numerical-NumberOfElectricalPhases needs to be a http://qudt.org/schema/qudt/QuantityKind\nhttp://example.org/HPL#FinnedHeatExchanger_A_ICP\n  - http://example.org/HPL#FinnedHeatExchanger_A_ICP expected 1 instance(s) of ns2:Connectable on path ns2:isConnectionPointOf\nhttp://example.org/HPL#FinnedHeatExchanger_R_CP_1\n  - http://example.org/HPL#FinnedHeatExchanger_R_CP_1 expected 1 instance(s) of ns2:Connectable on path ns2:isConnectionPointOf\nhttp://example.org/HPL#FinnedHeatExchanger_A_OCP\n  - http://example.org/HPL#FinnedHeatExchanger_A_OCP expected 1 instance(s) of ns2:Connectable on path ns2:isConnectionPointOf\nhttp://example.org/HPL#TemperatureSensor_15\n  - http://example.org/HPL#TemperatureSensor_15 expected 1 uses of path ns2:hasObservationLocation\nhttp://example.org/HPL#FinnedHeatExchanger_R_CP_2\n  - http://example.org/HPL#FinnedHeatExchanger on http://example.org/HPL#FinnedHeatExchanger_R_CP_2 needs to be a http://data.ashrae.org/standard223#Connectable\nhttp://data.ashrae.org/standard223#NumberOfElectricalPhases-SinglePhase\n  - http://qudt.org/vocab/quantitykind/NumberOfElectricalPhases on http://data.ashrae.org/standard223#NumberOfElectricalPhases-SinglePhase needs to be a http://qudt.org/schema/qudt/QuantityKind\nhttp://example.org/HPL#PressureSensor_8\n  - http://example.org/HPL#PressureSensor_8 expected 1 uses of path ns2:hasObservationLocation\nhttp://data.ashrae.org/standard223#NumberOfElectricalPhases-ThreePhase\n  - http://qudt.org/vocab/quantitykind/NumberOfElectricalPhases on http://data.ashrae.org/standard223#NumberOfElectricalPhases-ThreePhase needs to be a http://qudt.org/schema/qudt/QuantityKind\nhttp://example.org/HPL#OA_Unit\n  - http://example.org/HPL#OA_Unit needs to match one of the following shapes: nc501eec419fd46c78bfd246120b0d9abb1287, nc501eec419fd46c78bfd246120b0d9abb1288\n"},"key":"QCj6BlZYOJ"}],"key":"UziAziurEG"}],"key":"hVgJmXom7f"}],"key":"EYOwI8sowm"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"NREL Example Building","url":"/nrel-example","group":"Example Buildings"},"next":{"title":"Intelligent Buildings Agents Laboratory (IBAL)","url":"/nist-ibal","group":"Example Buildings"}}},"domain":"http://localhost:3000"}