n remove the ","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"okAQS6rdwb"},{"type":"inlineCode","value":"shacl_engine='topquadrant'","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"dUAcmxdLdd"},{"type":"text","value":" parameter from the ","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"Ahnle8jKK9"},{"type":"inlineCode","value":"BuildingMOTIF","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"OZDYrLjnuM"},{"type":"text","value":" constructor.\nBe warned that without the ","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"aKr5w78LhA"},{"type":"inlineCode","value":"shacl_engine='topquadrant'","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"Jf8MdwpAlb"},{"type":"text","value":" parameter, the validation process will be slower.","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"b85Favg3GM"}],"key":"QFsIGYp9Jw"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"BuildingMOTIF installation","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"key":"iefQDSEvos"}],"key":"MGHR3RAfI1"},{"type":"paragraph","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"children":[{"type":"text","value":"To install the ","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"cxAcC1JPcU"},{"type":"inlineCode","value":"buildingmotif","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"Rxs7JccuTD"},{"type":"text","value":" library, you can use the following command:","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"SaAguuyk2n"}],"key":"ZzzudVJx10"},{"type":"code","lang":"shell","value":"pip install 'buildingmotif[topquadrant] @ git+https://github.com/NREL/buildingmotif.git@develop'","position":{"start":{"line":72,"column":1},"end":{"line":74,"column":1}},"key":"UqH90ztPgb"},{"type":"paragraph","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"If you do not have Java installed, you can use the following command to install the library:","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"tkFcrGTyT2"}],"key":"rXyZ43zkcK"},{"type":"code","lang":"shell","value":"pip install 'buildingmotif @ git+https://github.com/NREL/buildingmotif.git@develop'","position":{"start":{"line":78,"column":1},"end":{"line":80,"column":1}},"key":"t3PMDwmKNt"}],"class":"dropdown","key":"VxJwhReXPq"}],"key":"amwo5K47NW"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from buildingmotif import BuildingMOTIF\nfrom buildingmotif.dataclasses import Library, Model\nimport ontoenv\nimport logging\n\n# Create a BuildingMOTIF object. If you do not have Java installed, remove the \"shacl_engine\" parameter\nbm = BuildingMOTIF('sqlite://', shacl_engine='topquadrant', log_level=logging.ERROR)\n\n# load 223P library. We will load a recent copy from the models.open223.info\n# git repository; later, we will load this from the location of the actual standard\ns223 = Library.load(ontology_graph=\"https://open223.info/223p.ttl\", infer_templates=False, run_shacl_inference=False)\nunit = Library.load(ontology_graph=\"http://qudt.org/3.1.1/vocab/unit\", infer_templates=False, run_shacl_inference=False)\nquantitykind = Library.load(ontology_graph=\"http://qudt.org/3.1.1/vocab/quantitykind\", infer_templates=False, run_shacl_inference=False)\n\n# load the model into the BuildingMOTIF instance\nmodel = Model.create(\"urn:guideline36-2021-A-8\")\nmodel.graph.parse(\"https://models.open223.info/guideline36-2021-A-8.ttl\")\n\n# validate the model against 223P ontology\nctx = model.validate([s223.get_shape_collection(),\n                      unit.get_shape_collection(),\n                      quantitykind.get_shape_collection()],\n                     error_on_missing_imports=False)\n\n# print the validation result\nprint(f\"Model is valid: {ctx.valid}\")\n\n# if the model is invalid, print the validation report\nif not ctx.valid:\n    print(ctx.report_string[:1000]) # first 1000 characters of the report\n\n# BuildingMOTIF can also interpret the report to provide recommendations on fixes\nfor focus_node, diffs in ctx.get_reasons_with_severity(\"Violation\").items():\n    if len(diffs) == 0:\n        continue\n    print(focus_node)\n    for diff in diffs:\n        print(\"  - \" + diff.reason())","key":"fAlByDP2ee"},{"type":"outputs","id":"PqnEACjlkg8TmW8GGcpS4","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Model is valid: 0\nValidation Report\nConforms: False\n\nValidation Results (14):\n\n--- Result 1 ---\nSeverity: sh:Warning\nFocus Node: <http://data.ashrae.org/standard223/1.0/data/guideline36-2021-A-8#DualDuctDischargeSensor-hot-deck-damper-position>\nMessage: s223: An `ObservableProperty` is usually referred to by a `Sensor` using the relation `observes`.\nPath: _:n11a893baf3bc46f080dbcb7e8f50729eb3\nSource Constraint: sh:MinCountConstraintComponent\nSource Shape: <urn:well-known/760859c4>\n\n--- Result 2 ---\nSeverity: sh:Warning\nFocus Node: <http://data.ashrae.org/standard223/1.0/data/guideline36-2021-A-8#zone-temp>\nMessage: s223: An `ObservableProperty` is usually referred to by a `Sensor` using the relation `observes`.\nPath: _:n11a893baf3bc46f080dbcb7e8f50729eb5\nSource Constraint: sh:MinCountConstraintComponent\nSource Shape: <urn:well-known/760859c4>\n\n--- Result 3 ---\nSeverity: sh:Warning\nFocus Node: <http://data.ashrae.org/standard223/1.0/data/guideline36-2021-A-8#DualDuctDischargeSensor-cold-deck-damper-posit\n"},"key":"bUVYzZwwsA"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"http://data.ashrae.org/standard223#Numerical-NumberOfElectricalPhases\n  - http://qudt.org/vocab/quantitykind/NumberOfElectricalPhases on http://data.ashrae.org/standard223#Numerical-NumberOfElectricalPhases needs to be a http://qudt.org/schema/qudt/QuantityKind\nhttp://data.ashrae.org/standard223#NumberOfElectricalPhases-SinglePhase\n  - http://qudt.org/vocab/quantitykind/NumberOfElectricalPhases on http://data.ashrae.org/standard223#NumberOfElectricalPhases-SinglePhase needs to be a http://qudt.org/schema/qudt/QuantityKind\nhttp://data.ashrae.org/standard223#NumberOfElectricalPhases-ThreePhase\n  - http://qudt.org/vocab/quantitykind/NumberOfElectricalPhases on http://data.ashrae.org/standard223#NumberOfElectricalPhases-ThreePhase needs to be a http://qudt.org/schema/qudt/QuantityKind\n"},"key":"bFP4saLfCD"}],"key":"RCtDqelZUF"}],"key":"F9DYh1Z29m"}],"key":"XzUn4dzo7v"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"ASHRAE Guideline 36-2021 A-7 Dual Duct Terminal Unit with Inlet Sensors","url":"/guideline36-2021-a-7","group":"Example Systems"},"next":{"title":"ASHRAE Guideline 36-2021 A-9 Multiple Zone VAV Air Handling Unit","url":"/guideline36-2021-a-9","group":"Example Systems"}}},"domain":"http://localhost:3001"}