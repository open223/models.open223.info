n remove the ","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"SydrYLTGFF"},{"type":"inlineCode","value":"shacl_engine='topquadrant'","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"oUUApmcOEe"},{"type":"text","value":" parameter from the ","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"ogpbdoGYUy"},{"type":"inlineCode","value":"BuildingMOTIF","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"NeUzT6S8Qx"},{"type":"text","value":" constructor.\nBe warned that without the ","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"gu5obwAV2r"},{"type":"inlineCode","value":"shacl_engine='topquadrant'","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"ZKkJzPxcC9"},{"type":"text","value":" parameter, the validation process will be slower.","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"zZAdmagSWd"}],"key":"BzhChyyZrv"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"BuildingMOTIF installation","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"key":"Ar8Cr6uvfF"}],"key":"DcdnaYz6hp"},{"type":"paragraph","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"children":[{"type":"text","value":"To install the ","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"NxchJPv2IC"},{"type":"inlineCode","value":"buildingmotif","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"mEHr2k6r1e"},{"type":"text","value":" library, you can use the following command:","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"jnToHBgnWK"}],"key":"rLf11UgGfW"},{"type":"code","lang":"shell","value":"pip install 'buildingmotif[topquadrant] @ git+https://github.com/NREL/buildingmotif.git@develop'","position":{"start":{"line":72,"column":1},"end":{"line":74,"column":1}},"key":"ciCi5XFkaP"},{"type":"paragraph","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"If you do not have Java installed, you can use the following command to install the library:","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"K4acL1DAAb"}],"key":"GgznnrVcJu"},{"type":"code","lang":"shell","value":"pip install 'buildingmotif @ git+https://github.com/NREL/buildingmotif.git@develop'","position":{"start":{"line":78,"column":1},"end":{"line":80,"column":1}},"key":"KsxSwzx1Ne"}],"class":"dropdown","key":"N6fe1EzKc4"}],"key":"MvLZgoX6KO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from buildingmotif import BuildingMOTIF\nfrom buildingmotif.dataclasses import Library, Model\nimport ontoenv\nimport logging\n\n# Create a BuildingMOTIF object. If you do not have Java installed, remove the \"shacl_engine\" parameter\nbm = BuildingMOTIF('sqlite://', shacl_engine='topquadrant', log_level=logging.ERROR)\n\n# load 223P library. We will load a recent copy from the models.open223.info\n# git repository; later, we will load this from the location of the actual standard\ns223 = Library.load(ontology_graph=\"https://open223.info/223p.ttl\", infer_templates=False, run_shacl_inference=False)\nunit = Library.load(ontology_graph=\"http://qudt.org/3.1.1/vocab/unit\", infer_templates=False, run_shacl_inference=False)\nquantitykind = Library.load(ontology_graph=\"http://qudt.org/3.1.1/vocab/quantitykind\", infer_templates=False, run_shacl_inference=False)\n\n# load the model into the BuildingMOTIF instance\nmodel = Model.create(\"urn:guideline36-2021-A-8\")\nmodel.graph.parse(\"https://models.open223.info/guideline36-2021-A-8.ttl\")\n\n# validate the model against 223P ontology\nctx = model.validate([s223.get_shape_collection(),\n                      unit.get_shape_collection(),\n                      quantitykind.get_shape_collection()],\n                     error_on_missing_imports=False)\n\n# print the validation result\nprint(f\"Model is valid: {ctx.valid}\")\n\n# if the model is invalid, print the validation report\nif not ctx.valid:\n    print(ctx.report_string[:1000]) # first 1000 characters of the report\n\n# BuildingMOTIF can also interpret the report to provide recommendations on fixes\nfor focus_node, diffs in ctx.get_reasons_with_severity(\"Violation\").items():\n    if len(diffs) == 0:\n        continue\n    print(focus_node)\n    for diff in diffs:\n        print(\"  - \" + diff.reason())","key":"MHQsMeBI6G"},{"type":"outputs","id":"jpoJNrvLw_ulu4-434g9Z","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Model is valid: 0\nValidation Report\nConforms: False\n\nValidation Results (14):\n\n--- Result 1 ---\nSeverity: sh:Warning\nFocus Node: <http://data.ashrae.org/standard223/1.0/data/guideline36-2021-A-8#DualDuctDischargeSensor-hot-deck-damper-position>\nMessage: s223: An `ObservableProperty` is usually referred to by a `Sensor` using the relation `observes`.\nPath: _:n8a70fd104a18478f9b72b1cde2b93373b3\nSource Constraint: sh:MinCountConstraintComponent\nSource Shape: <urn:well-known/99904f1d>\n\n--- Result 2 ---\nSeverity: sh:Warning\nFocus Node: <http://data.ashrae.org/standard223/1.0/data/guideline36-2021-A-8#zone-temp>\nMessage: s223: An `ObservableProperty` is usually referred to by a `Sensor` using the relation `observes`.\nPath: _:n8a70fd104a18478f9b72b1cde2b93373b5\nSource Constraint: sh:MinCountConstraintComponent\nSource Shape: <urn:well-known/99904f1d>\n\n--- Result 3 ---\nSeverity: sh:Warning\nFocus Node: <http://data.ashrae.org/standard223/1.0/data/guideline36-2021-A-8#DualDuctDischargeSensor-cold-deck-damper-posit\n"},"key":"EEFIJr4vmg"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"http://data.ashrae.org/standard223#Numerical-NumberOfElectricalPhases\n  - http://qudt.org/vocab/quantitykind/NumberOfElectricalPhases on http://data.ashrae.org/standard223#Numerical-NumberOfElectricalPhases needs to be a http://qudt.org/schema/qudt/QuantityKind\nhttp://data.ashrae.org/standard223#NumberOfElectricalPhases-SinglePhase\n  - http://qudt.org/vocab/quantitykind/NumberOfElectricalPhases on http://data.ashrae.org/standard223#NumberOfElectricalPhases-SinglePhase needs to be a http://qudt.org/schema/qudt/QuantityKind\nhttp://data.ashrae.org/standard223#NumberOfElectricalPhases-ThreePhase\n  - http://qudt.org/vocab/quantitykind/NumberOfElectricalPhases on http://data.ashrae.org/standard223#NumberOfElectricalPhases-ThreePhase needs to be a http://qudt.org/schema/qudt/QuantityKind\n"},"key":"FKb3ESWeYZ"}],"key":"izt2qVwD0D"}],"key":"ZG6eA6c86D"}],"key":"WtRkbCS3MP"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"ASHRAE Guideline 36-2021 A-7 Dual Duct Terminal Unit with Inlet Sensors","url":"/guideline36-2021-a-7","group":"Example Systems"},"next":{"title":"ASHRAE Guideline 36-2021 A-9 Multiple Zone VAV Air Handling Unit","url":"/guideline36-2021-a-9","group":"Example Systems"}}},"domain":"http://localhost:3001"}